{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/pages/(.*)",
      "destination": "/pages/$1"
    },
    {
      "source": "/docs/(.*)",
      "destination": "/docs/$1"
    },
    {
      "source": "/styles/(.*)",
      "destination": "/styles/$1"
    },
    {
      "source": "/scripts/(.*)",
      "destination": "/scripts/$1"
    },
    {
      "source": "/data/(.*)",
      "destination": "/data/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/$1"
    }
  ]
}